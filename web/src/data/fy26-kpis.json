{
  "departments": [
    {
      "id": "police",
      "name": "Police Department",
      "director": "Chief Paul Joye",
      "budgetDeptNames": ["Police"],
      "goals": [
        {
          "id": "police-g1",
          "title": "Reduce Violent Crime and Improve Public Safety",
          "objectives": [
            {
              "id": "police-g1-o1",
              "description": "Reduce violent crime incidents by 8% compared to FY25 baseline",
              "targetDate": "June 2026",
              "kpis": [
                { "metric": "Violent crime rate per 1,000 residents", "target": "< 4.2", "unit": "count", "category": "compliance" },
                { "metric": "Part I crime clearance rate", "target": "≥ 45", "unit": "%", "category": "compliance" }
              ]
            },
            {
              "id": "police-g1-o2",
              "description": "Achieve average Priority 1 response time under 5 minutes",
              "kpis": [
                { "metric": "Priority 1 avg response time", "target": "< 5:00", "unit": "min", "category": "response_time" },
                { "metric": "Priority 2 avg response time", "target": "< 9:00", "unit": "min", "category": "response_time" }
              ]
            }
          ]
        },
        {
          "id": "police-g2",
          "title": "Strengthen Community Relationships and Trust",
          "objectives": [
            {
              "id": "police-g2-o1",
              "description": "Increase community engagement events to 48 per year",
              "kpis": [
                { "metric": "Community engagement events held", "target": "48", "unit": "count", "category": "satisfaction" },
                { "metric": "Citizen satisfaction rating", "target": "≥ 75", "unit": "%", "category": "satisfaction" }
              ]
            },
            {
              "id": "police-g2-o2",
              "description": "Maintain fully staffed patrol divisions at 92% or above",
              "kpis": [
                { "metric": "Patrol staffing level", "target": "≥ 92", "unit": "%", "category": "staffing" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "fire",
      "name": "Fire Department",
      "director": "Chief Brian Moya",
      "budgetDeptNames": ["Fire"],
      "goals": [
        {
          "id": "fire-g1",
          "title": "Provide Rapid Emergency Response",
          "objectives": [
            {
              "id": "fire-g1-o1",
              "description": "Maintain average fire response time under 6 minutes citywide",
              "kpis": [
                { "metric": "Fire response time (avg)", "target": "< 6:00", "unit": "min", "category": "response_time" },
                { "metric": "EMS response time (avg)", "target": "< 7:00", "unit": "min", "category": "response_time" }
              ]
            },
            {
              "id": "fire-g1-o2",
              "description": "Achieve ISO Class 2 rating or better",
              "kpis": [
                { "metric": "ISO classification rating", "target": "≤ 2", "unit": "count", "category": "compliance" }
              ]
            }
          ]
        },
        {
          "id": "fire-g2",
          "title": "Enhance Firefighter Health, Safety, and Retention",
          "objectives": [
            {
              "id": "fire-g2-o1",
              "description": "Reduce on-duty injuries by 10% year-over-year",
              "kpis": [
                { "metric": "On-duty injury rate reduction", "target": "≥ 10", "unit": "%", "category": "staffing" },
                { "metric": "Firefighter retention rate", "target": "≥ 90", "unit": "%", "category": "staffing" }
              ]
            }
          ]
        }
      ]
    },
